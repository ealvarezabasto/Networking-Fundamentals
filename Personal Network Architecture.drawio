        <mxCell id="3kPFoN61AAtWGtaMyvLo-72" parent="1" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;" value="&lt;div style=&quot;&quot;&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Note:&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;ul&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;shared access network&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Uses existing standard twisted pair copper telephone lines&amp;nbsp;to provide internet access, employing different frequencies for voice and data transmission.&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;splitter: allowed phone and computer to be connected via the same wire&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;use &lt;i&gt;&lt;font style=&quot;color: rgb(255, 0, 0);&quot;&gt;existing&lt;/font&gt;&lt;/i&gt; telephone line to central office DSLAM&lt;/li&gt;&lt;ul&gt;&lt;li style=&quot;text-align: left;&quot;&gt;data over DSL phone line goes to Internet&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;voice over DSL phone line goes to telephone net&lt;br&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
